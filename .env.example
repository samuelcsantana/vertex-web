NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# This app's own public URL. Canonical/OpenGraph/sitemap/robots URLs are
# derived from the incoming request's Host header (src/lib/site-url.ts),
# so they always match whichever domain variant actually served the request
# (apex vs. www) — this var only feeds the root layout's static metadataBase
# and the fallback for contexts with no request Host. Still set it to the
# real production domain in deployment (e.g. https://www.samuelsantana.dev)
# so that fallback never points at localhost.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Base URL of the vertex-api backend, server-only. Server Actions/Components
# forward the HttpOnly access_token cookie to this URL directly.
VERTEX_API_URL="http://localhost:3333"

# Same backend URL, but browser-readable — used by Client Components that
# open OAuth popups directly (Google/GitHub login, GitHub account linking).
# Google/GitHub login redirects the popup to this app's own /auth/callback
# with a short-lived, single-use exchange code (never the real token) in
# the URL instead of vertex-api setting the cookie itself, since vertex-api
# and this app live on different domains and a cookie set by vertex-api's
# own response would be scoped to its domain, not this app's — see
# src/app/[locale]/auth/callback and exchangeOAuthCodeAction.
NEXT_PUBLIC_VERTEX_API_URL="http://localhost:3333"
