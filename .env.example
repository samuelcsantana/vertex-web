NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Base URL of the vertex-api backend, reachable from the browser — used by
# Client Components that open OAuth popups directly (Google/GitHub login,
# GitHub account linking). Server Actions and Server Components talk to the
# backend via the separate, non-public VERTEX_API_URL instead.
NEXT_PUBLIC_VERTEX_API_URL="http://localhost:3333"
