NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# This app's own public URL — used to build absolute canonical/OpenGraph
# URLs (root layout, blog post pages), and by sitemap.ts/robots.ts for the
# <loc>/hreflang entries and the Sitemap: line. Must be the real production
# domain in deployment (e.g. https://samuelsantana.dev), or those
# URLs will silently point at localhost.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Base URL of the vertex-api backend, server-only. Server Actions/Components
# forward the HttpOnly access_token cookie to this URL directly.
VERTEX_API_URL="http://localhost:3333"

# Same backend URL, but browser-readable — used by Client Components that
# open OAuth popups directly (Google/GitHub login, GitHub account linking).
# Google/GitHub login redirects the popup to this app's own /auth/callback
# with the token in the URL instead of vertex-api setting the cookie itself,
# since vertex-api and this app live on different domains and a cookie set
# by vertex-api's own response would be scoped to its domain, not this
# app's — see src/app/[locale]/auth/callback and setCookieAction.
NEXT_PUBLIC_VERTEX_API_URL="http://localhost:3333"
