NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Base URL of the vertex-api backend. Server Actions/Components forward the
# HttpOnly access_token cookie to this URL directly; next.config.ts also
# rewrites /auth/* here so OAuth (Google/GitHub login, GitHub linking) sets
# its session cookie on this app's own origin instead of the backend's
# separate domain, which the frontend's own cookies() calls could never see.
VERTEX_API_URL="http://localhost:3333"
